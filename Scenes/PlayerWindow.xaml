<?xml version="1.0" encoding="utf-8"?>
<Window
	x:Class="Media_Controller.PlayerWindow"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:local="using:Media_Controller"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	mc:Ignorable="d"
	Title="Media Controller">

	<Window.SystemBackdrop>
		<MicaBackdrop />
	</Window.SystemBackdrop>

	<StackPanel Orientation="Vertical">
		<StackPanel.Resources>
			<Style x:Key="WidgetButton" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
				<Setter Property="Padding" Value="0,0,0,0"/>
				<Setter Property="CornerRadius" Value="4"/>
				<Setter Property="BorderThickness" Value="0"/>
			</Style>
		</StackPanel.Resources>

		<Grid x:Name="TitleBar" Height="24">
			<Grid.ColumnDefinitions>
				<ColumnDefinition x:Name="LeftPaddingColumn" Width="0"/>
				<ColumnDefinition/>
				<ColumnDefinition x:Name="RightPaddingColumn" Width="0"/>
			</Grid.ColumnDefinitions>

			<StackPanel
				Grid.Column="1"
				Orientation="Horizontal"
				HorizontalAlignment="Right"
				Spacing="6">
				<StackPanel.Resources>
					<Style TargetType="Button" BasedOn="{StaticResource WidgetButton}">
						<Setter Property="Width" Value="30"/>
						<Setter Property="Height" Value="24"/>
						<Setter Property="Opacity" Value="0.5"/>
					</Style>
					<Style TargetType="FontIcon">
						<Setter Property="FontSize" Value="14"/>
					</Style>
				</StackPanel.Resources>
				
				<Button Click="SettingsBtn_Click">
					<FontIcon Glyph="&#xE712;" />
				</Button>

				<Button Click="MinimizeBtn_Click">
					<FontIcon Glyph="&#xE70D;" />
				</Button>

				<Button Click="CloseBtn_Click">
					<FontIcon Glyph="&#xE711;" />
				</Button>
			</StackPanel>
		</Grid>


		<StackPanel
			x:Name="Widget"
			Orientation="Horizontal"
			Margin="16,0,16,0">

			<Image
				x:Name="SongCover"
				Source="/Assets/GUI/Album_Test2.jpg"
				Height="100"
				VerticalAlignment="Top"
				Margin="0,0,16,0"/>


			<StackPanel
				Name="Controller"
				Orientation="Vertical"
				HorizontalAlignment="Center"
				Spacing="0">

				<TextBlock
					x:Name="LabelSong"
					Text="Bleak"
					FontSize="18"/>
				<TextBlock
					x:Name="LabelArtist"
					Text="Opeth"
					FontSize="12"
					Foreground="#b3b3b3"/>

				<StackPanel
					Name="TimeSlider"
					Orientation="Horizontal"
					HorizontalAlignment="Center"
					Spacing="8">

					<Slider
						Width="200"
						Minimum="500"
						Maximum="1000"
						StepFrequency="10"
						SmallChange="10"
						Value="780"/>

					<TextBlock
						x:Name="LabelTime"
						Text="00:00 / 00:00"
						VerticalAlignment="Center"
						FontSize="12"/>
				</StackPanel>

				<StackPanel
					Name="Buttons"
					Orientation="Horizontal"
					HorizontalAlignment="Center"
					Spacing="18"
					Margin="0,6,0,0">

					<StackPanel.Resources>
						<Style TargetType="Button" BasedOn="{StaticResource WidgetButton}">
							<Setter Property="Width" Value="33"/>
							<Setter Property="Height" Value="26"/>
							<Setter Property="Opacity" Value="0.75"/>
						</Style>
						<Style TargetType="FontIcon">
							<Setter Property="FontSize" Value="16"/>
						</Style>
					</StackPanel.Resources>


					<Button Click="PrevBtn_Click">
						<FontIcon Glyph="&#xE892;" />
					</Button>

					<Button Name="Play" Click="PlayBtn_Click">
						<FontIcon Glyph="&#xE768;" />
					</Button>

					<Button Click="NextBtn_Click">
						<FontIcon Glyph="&#xE893;" />
					</Button>
				</StackPanel>
			</StackPanel>
		</StackPanel>
	</StackPanel>
</Window>
