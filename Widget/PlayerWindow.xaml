<?xml version="1.0" encoding="utf-8"?>
<Window
	x:Class="Media_Controller.PlayerWindow"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:local="using:Media_Controller"
	xmlns:converters="using:Converters"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	mc:Ignorable="d"
	Title="Media Controller">

	<Window.SystemBackdrop>
		<MicaBackdrop />
	</Window.SystemBackdrop>

	<StackPanel Orientation="Vertical">
		<StackPanel.Resources>
			<Style x:Key="WidgetButton" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
				<Setter Property="Padding" Value="0,0,0,0"/>
				<Setter Property="CornerRadius" Value="4"/>
				<Setter Property="BorderThickness" Value="0"/>
			</Style>
			<converters:SliderTimeConverter x:Key="TimeConverter"/>
		</StackPanel.Resources>

		<Grid x:Name="TitleBar" Height="24">
			<Grid.ColumnDefinitions>
				<ColumnDefinition x:Name="LeftPaddingColumn" Width="0"/>
				<ColumnDefinition/>
				<ColumnDefinition x:Name="RightPaddingColumn" Width="0"/>
			</Grid.ColumnDefinitions>

			<StackPanel
				Grid.Column="1"
				Orientation="Horizontal"
				HorizontalAlignment="Right"
				Spacing="6">
				<StackPanel.Resources>
					<Style TargetType="Button" BasedOn="{StaticResource WidgetButton}">
						<Setter Property="Width" Value="30"/>
						<Setter Property="Height" Value="24"/>
						<Setter Property="Opacity" Value="0.5"/>
					</Style>
					<Style TargetType="FontIcon">
						<Setter Property="FontSize" Value="14"/>
					</Style>
				</StackPanel.Resources>

				<Button Click="BtnSettings_Click">
					<FontIcon Glyph="&#xE712;" />
				</Button>

				<Button Click="BtnMinimize_Click">
					<FontIcon Glyph="&#xE70D;" />
				</Button>

				<Button Click="BtnClose_Click">
					<FontIcon Glyph="&#xE711;" />
				</Button>
			</StackPanel>
		</Grid>


		<StackPanel
			x:Name="Widget"
			Orientation="Horizontal"
			Margin="16,0,16,0">


			<Rectangle
				x:Name="CoverContainer"
				Width="100"
				Height="100"
				HorizontalAlignment="Center"
				VerticalAlignment="Top"
				Margin="0,0,16,0">
				<Rectangle.Fill>
					<ImageBrush
						x:Name="CoverBrush"
						ImageSource="/Assets/Square44x44Logo.png"
						Stretch="UniformToFill"/>
				</Rectangle.Fill>
			</Rectangle>

			<StackPanel
				Name="Controller"
				Orientation="Vertical"
				HorizontalAlignment="Center"
				Spacing="0">

				<TextBlock
					x:Name="LabelSong"
					Text="Bleak"
					FontSize="18"/>
				<TextBlock
					x:Name="LabelArtist"
					Text="Opeth"
					FontSize="12"
					Foreground="#b3b3b3"/>

				<StackPanel
					Orientation="Horizontal"
					HorizontalAlignment="Center"
					Spacing="6"
					Width="300">

					<Slider
						x:Name="SliderTime"
						Width="180"
						Minimum="0"
						Maximum="1000"
						StepFrequency="1"
						SmallChange="5"
						Value="780"
						Margin="8,0,12,0"
						Loaded="Slider_Loaded"
						ThumbToolTipValueConverter="{StaticResource TimeConverter}">
					</Slider>

					<StackPanel
						Orientation="Horizontal"
						Spacing="6">
						<TextBlock
							x:Name="LabelTimeNow"
							Text="0:00"
							HorizontalTextAlignment="Left"
							VerticalAlignment="Center"
							FontSize="12"
							MinWidth="{Binding ElementName=LabelTimeTotal, Path=ActualWidth}"/>
						<TextBlock
							Text="/"
							VerticalAlignment="Center"
							FontSize="12"/>
						<TextBlock
							x:Name="LabelTimeTotal"
							Text="0:00"
							VerticalAlignment="Center"
							FontSize="12"/>
					</StackPanel>
				</StackPanel>

				<StackPanel
					Name="Buttons"
					Orientation="Horizontal"
					HorizontalAlignment="Center"
					Spacing="18"
					Margin="0,6,0,0">

					<StackPanel.Resources>
						<Style TargetType="Button" BasedOn="{StaticResource WidgetButton}">
							<Setter Property="Width" Value="33"/>
							<Setter Property="Height" Value="26"/>
							<Setter Property="Opacity" Value="0.75"/>
						</Style>
						<Style TargetType="FontIcon">
							<Setter Property="FontSize" Value="16"/>
						</Style>
					</StackPanel.Resources>

					<Button x:Name="PrevBtn" Click="BtnPrev_Click">
						<FontIcon Glyph="&#xE892;" />
					</Button>

					<Button x:Name="PlayBtn" Click="BtnPlay_Click">
						<FontIcon x:Name="PlaySym" Glyph="&#xE768;" />
					</Button>

					<Button x:Name="NextBtn" Click="BtnNext_Click">
						<FontIcon Glyph="&#xE893;" />
					</Button>
				</StackPanel>
			</StackPanel>
		</StackPanel>
	</StackPanel>
</Window>
